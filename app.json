{
  "expo": {
    "name": "rotina-app",
    "slug": "rotina-app",
    "version": "1.0.0",
    "scheme": "rotina-app",
    "orientation": "portrait",
    "icon": "./assets/RotinaAPP.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/RotinaAPPIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Permissão para acessar sua localização e mostrar no mapa."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/RotinaAPP.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.rotinaapp",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/RotinaAPP.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permissão para acessar sua localização e mostrar no mapa."
        }
      ]
    ]
  }
}
